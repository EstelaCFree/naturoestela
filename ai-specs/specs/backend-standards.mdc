## Clean Architecture Principles

### Domain Entities

Entities are plain Python dataclasses or Pydantic models with no ORM coupling.

```python
# domain/entities/appointment.py
from dataclasses import dataclass, field
from datetime import datetime
from uuid import UUID, uuid4

@dataclass
class Appointment:
    patient_id: UUID
    practitioner_id: UUID
    scheduled_at: datetime
    notes: str = ""
    id: UUID = field(default_factory=uuid4)
```

### Repository Interfaces

Abstract interfaces live in the domain layer. Infrastructure implements them.

```python
# domain/repositories/appointment_repository.py
from abc import ABC, abstractmethod
from uuid import UUID
from ..entities.appointment import Appointment

class AppointmentRepository(ABC):
    @abstractmethod
    async def find_by_id(self, appointment_id: UUID) -> Appointment | None: ...

    @abstractmethod
    async def save(self, appointment: Appointment) -> Appointment: ...

    @abstractmethod
    async def find_by_patient(self, patient_id: UUID) -> list[Appointment]: ...
```

### Use Cases

One use case per file. Use cases receive dependencies via constructor injection.

```python
# application/use_cases/create_appointment.py
from uuid import UUID
from ..dtos.appointment_dto import CreateAppointmentDTO, AppointmentDTO
from ...domain.repositories.appointment_repository import AppointmentRepository
from ...domain.entities.appointment import Appointment

class CreateAppointment:
    def __init__(self, repository: AppointmentRepository) -> None:
        self._repository = repository

    async def execute(self, dto: CreateAppointmentDTO) -> AppointmentDTO:
        appointment = Appointment(
            patient_id=dto.patient_id,
            practitioner_id=dto.practitioner_id,
            scheduled_at=dto.scheduled_at,
            notes=dto.notes,
        )
        saved = await self._repository.save(appointment)
        return AppointmentDTO.from_entity(saved)
```

### Infrastructure Repositories

Concrete SQLAlchemy implementations live in infrastructure.

```python
# infrastructure/repositories/sqlalchemy_appointment_repository.py
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select
from uuid import UUID
from ...domain.entities.appointment import Appointment
from ...domain.repositories.appointment_repository import AppointmentRepository
from ..database.models import AppointmentModel

class SQLAlchemyAppointmentRepository(AppointmentRepository):
    def __init__(self, session: AsyncSession) -> None:
        self._session = session

    async def find_by_id(self, appointment_id: UUID) -> Appointment | None:
        result = await self._session.execute(
            select(AppointmentModel).where(AppointmentModel.id == appointment_id)
        )
        model = result.scalar_one_or_none()
        return model.to_entity() if model else None

    async def save(self, appointment: Appointment) -> Appointment:
        model = AppointmentModel.from_entity(appointment)
        self._session.add(model)
        await self._session.flush()
        return model.to_entity()
```

### Dependency Injection via FastAPI

Wire dependencies using FastAPI's `Depends`.

```python
# presentation/routers/appointments.py
from fastapi import APIRouter, Depends
from sqlalchemy.ext.asyncio import AsyncSession
from ...infrastructure.database.session import get_session
from ...infrastructure.repositories.sqlalchemy_appointment_repository import SQLAlchemyAppointmentRepository
from ...application.use_cases.create_appointment import CreateAppointment
from ..schemas.appointment_schema import CreateAppointmentRequest, AppointmentResponse

router = APIRouter(prefix="/appointments", tags=["appointments"])

def get_create_appointment_use_case(
    session: AsyncSession = Depends(get_session),
) -> CreateAppointment:
    return CreateAppointment(SQLAlchemyAppointmentRepository(session))

@router.post("/", response_model=AppointmentResponse, status_code=201)
async def create_appointment(
    body: CreateAppointmentRequest,
    use_case: CreateAppointment = Depends(get_create_appointment_use_case),
) -> AppointmentResponse:
    result = await use_case.execute(body.to_dto())
    return AppointmentResponse.from_dto(result)
```

